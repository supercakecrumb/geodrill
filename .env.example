# Telegram bot token from @BotFather
TELEGRAM_TOKEN=123456:ABC-your-token-here

# Telegram chat id that scripts/notify.sh sends progress messages to.
# Kept only here in the gitignored .env — never in tracked source (public repo).
TELEGRAM_CHAT_ID=000000000

# PostgreSQL connection string (matches docker-compose defaults)
DATABASE_URL=postgres://geodrill:geodrill@db:5432/geodrill?sslmode=disable

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Optional FSRS target retention in (0,1); default 0.9
# FSRS_RETENTION=0.9

# snagbox feedback reporting (the /feedback command files issues into snagbox).
# Both are OPTIONAL — leave them unset and /feedback replies "not available".
# The ingest token is write-only and scoped to geodrill's snagbox project;
# keep it server-side only (it lives in the gitignored .env, never in source).
SNAGBOX_URL=https://snagbox.example.com
SNAGBOX_INGEST_TOKEN=snb_your-write-only-ingest-token-here

# Garage S3 (object store for city-map images). Optional — unset = the bot
# won't fetch S3-backed images (city maps degrade to text). Server-side only:
# the access key + secret are sourced from OpenBao in production and must never
# be committed (this file is gitignored). Region and bucket have defaults
# (garage / apps-geodrill) so they can be left unset for a standard deployment.
GARAGE_S3_ENDPOINT=http://garage:3900
GARAGE_S3_REGION=garage
GARAGE_ACCESS_KEY_ID=
GARAGE_SECRET_ACCESS_KEY=
GARAGE_BUCKET=apps-geodrill

# Postgres credentials used by docker-compose (optional overrides)
POSTGRES_USER=geodrill
POSTGRES_PASSWORD=geodrill
POSTGRES_DB=geodrill
POSTGRES_PORT=5432
